# Kopiraj u .env i popuni svoje vrednosti
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/ancora
JWT_SECRET=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Gmail SMTP (ostavi prazno za dev fallback — link u konzoli)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=Ancora <your-email@gmail.com>
